/data/

# --- Go build output ---
*.exe
*.exe~
*.dll
*.so
*.dylib
/server/bin/
*.test
/coverage.out

# --- Node / Next.js ---
node_modules/
.next/
out/
build/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- Environment & secrets ---
.env
.env.local
.env.*.local
!.env*.example

# --- Logs & temp ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tmp

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE (local) ---
.idea/
.vscode/
*.swp
*.swo
*~
