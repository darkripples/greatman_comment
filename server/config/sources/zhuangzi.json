{
  "characterId": "zhuangzi",
  "passages": [
    {
      "title": "逍遥",
      "text": "至人无己，神人无功，圣人无名。",
      "tags": [
        "逍遥",
        "自由"
      ],
      "source": "《庄子·逍遥游》"
    },
    {
      "title": "齐物",
      "text": "物无非彼，物无非是。自彼则不见，自是则知之。",
      "tags": [
        "齐物",
        "相对"
      ],
      "source": "《庄子·齐物论》"
    },
    {
      "title": "濠梁",
      "text": "子非鱼，安知鱼之乐？",
      "tags": [
        "相对",
        "认知"
      ],
      "source": "《庄子·秋水》"
    },
    {
      "title": "无用",
      "text": "无用之用，是为大用。",
      "tags": [
        "无用",
        "自然"
      ],
      "source": "《庄子·人间世》"
    },
    {
      "title": "庖丁",
      "text": "臣之所好者道也，进乎技矣。",
      "tags": [
        "技艺",
        "自然"
      ],
      "source": "《庄子·养生主》"
    },
    {
      "title": "梦蝶",
      "text": "不知周之梦为蝴蝶与，蝴蝶之梦为周与？",
      "tags": [
        "相对",
        "生命"
      ],
      "source": "《庄子·齐物论》"
    },
    {
      "title": "曳尾",
      "text": "宁其死为留骨而贵乎，其死为枯槁而贵乎？",
      "tags": [
        "自由",
        "名利"
      ],
      "source": "《庄子·秋水》"
    },
    {
      "title": "鼓盆",
      "text": "方其梦也，不知其梦也；且有大觉，而后知此其大梦也。",
      "tags": [
        "生死",
        "相对"
      ],
      "source": "《庄子·大宗师》"
    },
    {
      "title": "鹪鹩",
      "text": "鹪鹩巢于深林，不过一枝；偃鼠饮河，不过满腹。",
      "tags": [
        "知足",
        "逍遥"
      ],
      "source": "《庄子·逍遥游》"
    },
    {
      "title": "真者",
      "text": "真者，精诚之至也。不精不诚，不能动人。",
      "tags": [
        "真诚",
        "自然"
      ],
      "source": "《庄子·渔父》"
    },
    {
      "title": "功名",
      "text": "名者，实之宾也。",
      "tags": [
        "名利",
        "相对"
      ],
      "source": "《庄子·人间世》"
    },
    {
      "title": "水",
      "text": "水静则明烛须眉，平中准，大匠取法焉。",
      "tags": [
        "自然",
        "静观"
      ],
      "source": "《庄子·天地》"
    },
    {
      "title": "内卷",
      "text": "吾生也有涯，而知也无涯。以有涯随无涯，殆已。",
      "tags": [
        "生命",
        "知识"
      ],
      "source": "《庄子·养生主》"
    },
    {
      "title": "躺平",
      "text": "安时而处顺，哀乐不能入也，此古者所谓遁天者。",
      "tags": [
        "安命",
        "逍遥"
      ],
      "source": "《庄子·养生主》"
    },
    {
      "title": "相对",
      "text": "彼亦一是非，此亦一是非。",
      "tags": [
        "齐物",
        "舆论"
      ],
      "source": "《庄子·齐物论》"
    }
  ]
}
